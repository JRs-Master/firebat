            "required": [
              "date",
              "close"
            ],
            "additionalProperties": false
          },
          "description": "OHLCV 배열 — 오래된 → 최신 순서. 최소 10일 이상 권장. open/high/low/volume 누락 시 close 로 폴백(플랫 캔들)"
        },
        "indicators": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "MA5",
              "MA10",
              "MA20",
              "MA60"
            ]
          },
          "description": "이동평균선. 기본 [\"MA5\",\"MA20\"]. 불필요하면 []"
        },
        "buyPoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "price": {
                "type": "number"
              },
              "note": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "date": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "봉 날짜(데이터 date 와 일치). 있으면 해당 봉 아래 ↑ 매수 화살표, 없으면 price 레벨 수평선(지지)"
              }
            },
            "required": [
              "label",
              "price",
              "note"
            ],
            "additionalProperties": false
          },
          "description": "매수 신호. date 있으면 해당 봉에 ↑ 화살표(매수 시점), 없으면 price 레벨 수평선(지지선). 없으면 []"
        },
        "sellPoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "price": {
                "type": "number"
              },
              "note": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "date": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "봉 날짜(데이터 date 와 일치). 있으면 해당 봉 위 ↓ 매도 화살표, 없으면 price 레벨 수평선(저항)"
              }
            },
            "required": [
              "label",
              "price",
              "note"
            ],
            "additionalProperties": false
          },
          "description": "매도 신호. date 있으면 해당 봉에 ↓ 화살표(매도 시점), 없으면 price 레벨 수평선(저항선). 없으면 []"
        }
      }
    }
