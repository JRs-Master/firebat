# ============================================================
# FIREBAT .env.local 설정 템플릿
# 이 파일을 복사해서 .env.local 로 저장하고 값을 채워주세요.
# .env.local 은 .gitignore 에 의해 커밋되지 않습니다.
# ============================================================

# ------------------------------------------------------------
# 관리자 계정
# 미설정 시 기본값: admin / admin (보안상 반드시 변경할 것)
# 설정 이후에는 관리자 페이지 > System Settings 에서도 변경 가능합니다.
# ------------------------------------------------------------
FIREBAT_ADMIN_ID=admin
FIREBAT_ADMIN_PASSWORD=admin

# ------------------------------------------------------------
# 데모 모드 (true 설정 시 user/user 계정 활성화, 설정 접근 불가)
# ------------------------------------------------------------
FIREBAT_DEMO=false

# ------------------------------------------------------------
# Vertex AI (필수)
# Google Cloud Console에서 Vertex AI API 활성화 후 발급
# 설정 페이지(톱니바퀴)에서 입력하면 Vault DB에 저장되므로
# 환경변수는 서버 초기 세팅 또는 CI/CD용으로만 사용합니다.
# ------------------------------------------------------------
VERTEX_AI_API_KEY=
VERTEX_AI_PROJECT=        # GCP 프로젝트 ID (선택, Express 모드 시 불필요)
VERTEX_AI_LOCATION=us-central1  # 기본값: us-central1
