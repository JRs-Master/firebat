{
  "name": "kiwoom-order",
  "type": "module",
  "scope": "system",
  "version": "1.0.0",
  "description": "키움증권 주문 (현금/신용/금현물 매수·매도·정정·취소)",
  "runtime": "node",
  "capability": "stock-trading",
  "providerType": "api",
  "secrets": [
    "KIWOOM_APP_KEY",
    "KIWOOM_APP_SECRET"
  ],
  "tokenCache": {
    "secretName": "KIWOOM_ACCESS_TOKEN",
    "ttlHours": 23
  },
  "input": {
    "type": "object",
    "required": [
      "action"
    ],
    "properties": {
      "action": {
        "type": "string",
        "enum": [
          "kt10000",
          "kt10001",
          "kt10002",
          "kt10003",
          "kt10006",
          "kt10007",
          "kt10008",
          "kt10009",
          "kt50000",
          "kt50001",
          "kt50002",
          "kt50003"
        ],
        "description": "키움 API ID 직접 호출. 본 sysmod 가 지원하는 API:\n  kt10000 — 주식 매수주문\n  kt10001 — 주식 매도주문\n  kt10002 — 주식 정정주문\n  kt10003 — 주식 취소주문\n  kt10006 — 신용 매수주문\n  kt10007 — 신용 매도주문\n  kt10008 — 신용 정정주문\n  kt10009 — 신용 취소주문\n  kt50000 — 금현물 매수주문\n  kt50001 — 금현물 매도주문\n  kt50002 — 금현물 정정주문\n  kt50003 — 금현물 취소주문"
      },
      "params": {
        "type": "object",
        "description": "키움 API request body 의 모든 필드를 그대로 전달. 각 API 의 필드는 키움 REST API 문서 또는 위 action 설명 참조."
      },
      "mock": {
        "type": "boolean",
        "description": "true 면 모의투자 도메인 (mockapi.kiwoom.com) 호출. 기본 false (실전)."
      }
    },
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "properties": {
      "apiId": {
        "type": "string"
      },
      "action": {
        "type": "string"
      }
    }
  }
}