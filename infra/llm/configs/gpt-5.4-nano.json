{
  "id": "gpt-5.4-nano",
  "displayName": "GPT-5.4 Nano",
  "provider": "openai",
  "format": "openai-responses",
  "endpoint": "https://api.openai.com/v1/responses",
  "apiKeyVaultKey": "OPENAI_API_KEY",
  "features": {
    "mcpConnector": true,
    "strictTools": true,
    "reasoning": true,
    "previousResponseId": true,
    "promptCache24h": true,
    "vision": true,
    "temperature": false
  },
  "pricing": { "input": 0.20, "output": 1.25, "cachedInput": 0.02 }
}
