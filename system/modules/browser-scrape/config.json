{
  "name": "browser-scrape",
  "type": "module",
  "scope": "system",
  "version": "1.0.0",
  "description": "Playwright-based JS-rendering web scraper. Use for any page that cannot be fetched with static requests — dynamic JS pages, search engine results, etc.",
  "runtime": "python",
  "capability": "web-scrape",
  "providerType": "local",
  "packages": [
    {
      "name": "playwright==1.59.1",
      "heavy": true,
      "estimatedSec": 600,
      "postInstall": "python -m playwright install chromium"
    }
  ],
  "settings_fields": [
    {
      "key": "timeout",
      "type": "number",
      "placeholder": "30000",
      "defaultValue": 30000
    },
    {
      "key": "headless",
      "type": "toggle",
      "defaultValue": true
    },
    {
      "key": "maxTextLength",
      "type": "number",
      "placeholder": "50000",
      "defaultValue": 50000
    }
  ],
  "input": {
    "type": "object",
    "required": ["url"],
    "properties": {
      "url": {
        "type": "string",
        "format": "uri",
        "description": "URL to scrape"
      },
      "selector": {
        "type": "string",
        "description": "CSS selector. If provided, returns only the matching element"
      },
      "waitFor": {
        "type": "string",
        "enum": ["networkidle", "load", "domcontentloaded", "commit"],
        "default": "networkidle",
        "description": "Page load wait strategy"
      },
      "waitForSelector": {
        "type": "string",
        "description": "Wait until this CSS selector appears"
      },
      "excludeDomains": {
        "type": "array",
        "items": { "type": "string" },
        "description": "List of domains to exclude when filtering links"
      },
      "viewport": {
        "type": "object",
        "properties": {
          "width":  { "type": "integer", "default": 1280, "description": "Viewport width" },
          "height": { "type": "integer", "default": 720, "description": "Viewport height" }
        },
        "additionalProperties": false,
        "description": "Browser viewport size"
      },
      "locale": {
        "type": "string",
        "default": "ko-KR",
        "description": "Browser locale (BCP 47)"
      },
      "timezoneId": {
        "type": "string",
        "default": "Asia/Seoul",
        "description": "Browser timezone (IANA)"
      },
      "extraHeaders": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Additional HTTP headers"
      },
      "javascriptEnabled": {
        "type": "boolean",
        "default": true,
        "description": "Whether to execute JavaScript"
      },
      "screenshot": {
        "type": "boolean",
        "default": false,
        "description": "Capture a screenshot (returned as base64)"
      },
      "fullPage": {
        "type": "boolean",
        "default": false,
        "description": "Full-page screenshot (when screenshot=true)"
      }
    },
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "required": ["url", "title", "text"],
    "properties": {
      "url":   { "type": "string", "description": "Final URL (after redirects)" },
      "title": { "type": "string", "description": "Page title" },
      "text":  { "type": "string", "description": "Page body text" },
      "links": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["href", "text"],
          "properties": {
            "href": { "type": "string", "description": "Link URL" },
            "text": { "type": "string", "description": "Link text" }
          },
          "additionalProperties": false
        },
        "description": "External links on the page (up to 10)"
      },
      "firstLink": {
        "type": ["object", "null"],
        "properties": {
          "href": { "type": "string" },
          "text": { "type": "string" }
        },
        "additionalProperties": false,
        "description": "First external link"
      },
      "screenshot": {
        "type": "string",
        "description": "Screenshot base64 data (when screenshot=true)"
      }
    },
    "additionalProperties": false
  }
}
