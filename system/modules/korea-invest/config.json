        "description": "편의 액션명 (영문 그대로 사용). price=현재가, quote=호가, balance=잔고, chart-daily=일봉, ranking-volume=거래량순위 등. 또는 trId+url 필드로 직접 지정."
      },
      "symbol": {
        "type": "string",
        "description": "종목코드. 국내: 보통 6자리 숫자 (005930=삼성전자) — 단 ETN/ETF/일부 신규상장 종목은 영문 포함 6자리 (예: 0011T0=채비). 해외: 알파벳 ticker (AAPL). 형식 검증 X — 받은 코드 그대로 API 에 전달."
      },
      "exchange": {
        "type": "string",
        "enum": ["NAS", "NYS", "AMS", "TSE", "HKS", "SHS", "SZS", "HSX", "HNX", "CME", "EUREX", "SGX"],
        "description": "해외 거래소 코드 (NAS=나스닥, NYS=뉴욕, TSE=도쿄, CME/EUREX/SGX=선물거래소 등). 해외 액션에 필수."
      },
      "accountNo": {
        "type": "string",
        "description": "계좌번호 앞 8자리 (계좌 조회 시 필요)"
      },
      "accountProductCode": {
        "type": "string",
        "default": "01",
        "description": "계좌상품코드 뒤 2자리 (기본 01)"
      },
      "trId": {
        "type": "string",
        "description": "한투 TR_ID 직접 지정 (API 문서 참조)"
      },
      "url": {
        "type": "string",
        "description": "API URL 경로 직접 지정 (trId 사용 시 필수)"
      },
      "method": {
        "type": "string",
        "enum": ["GET", "POST"],
        "default": "GET",
        "description": "HTTP 메서드"
      },
      "params": {
        "type": "object",
        "description": "API별 추가 파라미터 (GET=query, POST=body)"
      },
      "quantity": {
        "type": "integer",
        "minimum": 1,
        "description": "주문 수량"
      },
      "price": {
        "type": "integer",
        "minimum": 0,
        "description": "주문 가격 (0=시장가)"
      },
      "period": {
        "type": "string",
        "enum": ["D", "W", "M", "Y"],
        "default": "D",
        "description": "차트 기간 (D=일, W=주, M=월, Y=년)"
      },
      "mock": {
        "type": "boolean",
        "default": false,
        "description": "모의투자 여부 (기본값: false=실전투자)"
