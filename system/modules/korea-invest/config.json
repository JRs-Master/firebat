  "output": {
    "type": "object",
    "required": ["trId"],
    "properties": {
      "trId": { "type": "string", "description": "호출된 TR_ID" },
      "action": { "type": "string", "description": "요청한 액션명" },
      "data": { "type": "object", "description": "API 응답 데이터 (API별로 다름)" }
    },
    "additionalProperties": true
  }
