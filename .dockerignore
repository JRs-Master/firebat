# Docker build context 제외 — image 크기 / 빌드 속도 위해 불필요한 파일 차단.
# Phase C (2026-05-12) — Dockerfile.core + Dockerfile.renderer 공통.

# ── Build artifacts ──
target/           # Rust build cache (GB 단위)
**/target/
node_modules/
**/node_modules/
.next/
**/.next/
dist/
**/dist/

# ── 사용자 / 영속 데이터 (volume mount 대상) ──
data/             # SQLite DB / Vault / cron 잡 — compose volume 에서 마운트
user/             # 사용자 모듈 / 미디어 / 첨부 — volume 마운트
# system/ 은 image 안 포함 (sysmod 정의는 image 의 일부)

# ── 환경 / 비밀 ──
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ── 로컬 개발 / 도구 ──
.git/
.gitignore
.github/
.vscode/
.idea/
.claude/
.cursor/
CLAUDE.md         # 작업 로그 — image 와 무관

# ── 빌드 산출물 / 임시 ──
*.log
**/*.log
.DS_Store
Thumbs.db
*.tmp
tmp/

# ── 테스트 / docs ──
__tests__/
**/__tests__/
docs/
*.md
!README.md
coverage/
.nyc_output/

# ── Tauri (폐기됨) / 옛 src ──
src-tauri/
