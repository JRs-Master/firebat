{
  "name": "firecrawl",
  "type": "module",
  "scope": "system",
  "version": "2.0.0",
  "description": "Web scraper based on Firecrawl API v1. Four actions: scrape (single URL), crawl (entire site), map (collect URL list), extract (LLM-structured data extraction). Supports JS rendering, browser actions (click/write/press/scroll/wait/screenshot), LLM JSON extraction, and location-based scraping.",
  "runtime": "node",
  "capability": "web-scrape",
  "providerType": "api",
  "secrets": ["FIRECRAWL_API_KEY"],
  "settings_fields": [
    {
      "key": "maxTextLength",
      "type": "number",
      "placeholder": "30000",
      "defaultValue": 30000
    }
  ],
  "input": {
    "type": "object",
    "properties": {
      "action": {
        "type": "string",
        "enum": ["scrape", "crawl", "map", "extract"],
        "default": "scrape",
        "description": "scrape=single URL scrape, crawl=full site crawl, map=collect URL list (no scraping), extract=LLM-structured data extraction"
      },
      "url": {
        "type": "string",
        "description": "[scrape/crawl/map] Target URL"
      },
      "urls": {
        "type": "array",
        "items": { "type": "string" },
        "description": "[extract] Target URL array. Supports wildcards (example.com/*)"
      },
      "keyword": {
        "type": "string",
        "description": "[scrape] Extract only sections containing the keyword (post-processed locally)"
      },
      "formats": {
        "type": "array",
        "items": { "type": "string", "enum": ["markdown", "html", "rawHtml", "json", "links", "screenshot", "screenshot@fullPage"] },
        "default": ["markdown"],
        "description": "[scrape] Return formats. json=LLM-structured extraction (requires jsonOptions)"
      },
      "onlyMainContent": {
        "type": "boolean",
        "default": true,
        "description": "[scrape] Extract only the main content (excludes nav/footer)"
      },
      "includeTags": {
        "type": "array",
        "items": { "type": "string" },
        "description": "[scrape] HTML tags to include"
      },
      "excludeTags": {
        "type": "array",
        "items": { "type": "string" },
        "description": "[scrape] HTML tags to exclude"
      },
      "headers": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "[scrape] Custom HTTP headers"
      },
      "waitFor": {
        "type": "integer",
        "description": "[scrape] Wait after page load (ms). Also accepts a CSS selector string"
      },
      "timeout": {
        "type": "integer",
        "default": 45000,
        "description": "[scrape] Render timeout (ms). Default 45000. Raise for slow / heavy-JS pages, but capped at 48000 (sandbox run limit is 60s)."
      },
      "mobile": {
        "type": "boolean",
        "default": false,
        "description": "[scrape] Use a mobile viewport"
      },
      "skipTlsVerification": {
        "type": "boolean",
        "default": false,
        "description": "[scrape] Skip TLS certificate verification"
      },
      "removeBase64Images": {
        "type": "boolean",
        "default": true,
        "description": "[scrape] Strip base64 images"
      },
      "maxAge": {
        "type": "integer",
        "default": 0,
        "description": "[scrape] Maximum cache age (ms). 0=disable cache"
      },
      "location": {
        "type": "object",
        "properties": {
          "country": { "type": "string", "description": "ISO 3166-1 alpha-2 country code (e.g., US, KR)" },
          "languages": { "type": "array", "items": { "type": "string" }, "description": "Preferred language array (e.g., ko, en)" }
        },
        "description": "[scrape/map] Location/language-based scraping"
      },
      "actions": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["click", "write", "press", "scroll", "wait", "screenshot", "scrape", "executeJavaScript"], "description": "Action type" },
            "selector": { "type": "string", "description": "[click/write] CSS selector" },
            "text": { "type": "string", "description": "[write] Text to type" },
            "key": { "type": "string", "description": "[press] Keyboard key (Enter, Tab, etc.)" },
            "milliseconds": { "type": "integer", "description": "[wait] Wait time (ms)" },
            "fullPage": { "type": "boolean", "description": "[screenshot] Capture full page" },
            "direction": { "type": "string", "enum": ["up", "down"], "description": "[scroll] Scroll direction" },
            "amount": { "type": "integer", "description": "[scroll] Scroll amount (px)" },
            "script": { "type": "string", "description": "[executeJavaScript] JS code" }
          }
        },
        "description": "[scrape] Browser actions to run before scraping. Login, button clicks, infinite scroll, etc."
      },
      "jsonOptions": {
        "type": "object",
        "properties": {
          "schema": { "type": "object", "description": "Data structure to extract, defined as a JSON Schema" },
          "prompt": { "type": "string", "description": "Natural-language description of the data to extract" },
          "systemPrompt": { "type": "string", "description": "LLM system prompt" }
        },
        "description": "[scrape] Options for LLM-based structured extraction when formats includes 'json'"
      },
      "limit": {
        "type": "integer",
        "description": "[crawl] Maximum number of pages (default 10000). [map] Maximum number of URLs"
      },
      "maxDiscoveryDepth": {
        "type": "integer",
        "description": "[crawl] Maximum link depth from the root URL"
      },
      "includePaths": {
        "type": "array",
        "items": { "type": "string" },
        "description": "[crawl] Regex patterns for URL paths to include"
      },
      "excludePaths": {
        "type": "array",
        "items": { "type": "string" },
        "description": "[crawl] Regex patterns for URL paths to exclude"
      },
      "crawlEntireDomain": {
        "type": "boolean",
        "default": false,
        "description": "[crawl] Crawl parent and sibling URLs as well"
      },
      "allowSubdomains": {
        "type": "boolean",
        "default": false,
        "description": "[crawl] Crawl subdomains too"
      },
      "allowExternalLinks": {
        "type": "boolean",
        "default": false,
        "description": "[crawl/extract] Follow external links"
      },
      "sitemap": {
        "type": "string",
        "enum": ["include", "skip", "only"],
        "description": "[crawl] Sitemap handling. include=include, skip=ignore, only=sitemap only"
      },
      "ignoreQueryParameters": {
        "type": "boolean",
        "default": false,
        "description": "[crawl] Deduplicate the same path with different query parameters"
      },
      "delay": {
        "type": "number",
        "description": "[crawl] Delay between scrapes (seconds)"
      },
      "maxConcurrency": {
        "type": "integer",
        "description": "[crawl] Maximum concurrent scrapes"
      },
      "scrapeOptions": {
        "type": "object",
        "description": "[crawl] Per-page scraping options (formats, actions, etc.)"
      },
      "search": {
        "type": "string",
        "description": "[map] Search keyword to filter URLs"
      },
      "prompt": {
        "type": "string",
        "description": "[extract] Natural-language description of the data to extract"
      },
      "schema": {
        "type": "object",
        "description": "[extract] Data structure to extract, defined as a JSON Schema"
      },
      "systemPrompt": {
        "type": "string",
        "description": "[extract] LLM system prompt"
      },
      "enableWebSearch": {
        "type": "boolean",
        "description": "[extract] Augment with related information via web search"
      },
      "showSources": {
        "type": "boolean",
        "description": "[extract] Include source URLs"
      },
      "maxWaitMs": {
        "type": "integer",
        "default": 300000,
        "description": "[crawl/extract] Maximum wait time (ms). crawl defaults to 5 minutes, extract to 2 minutes"
      },
      "pollInterval": {
        "type": "integer",
        "default": 5000,
        "description": "[crawl] Polling interval (ms)"
      }
    },
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "properties": {
      "url": { "type": "string", "description": "[scrape] Final URL" },
      "title": { "type": "string", "description": "[scrape] Page title" },
      "text": { "type": "string", "description": "[scrape] Markdown body" },
      "html": { "type": "string", "description": "[scrape] HTML (when formats includes html)" },
      "links": { "type": "array", "description": "[scrape/map] List of links" },
      "screenshot": { "type": "string", "description": "[scrape] Screenshot URL" },
      "json": { "type": "object", "description": "[scrape] LLM-extracted JSON (when formats includes json)" },
      "pages": { "type": "array", "description": "[crawl] Array of crawled pages [{url, title, text}]" },
      "crawlId": { "type": "string", "description": "[crawl] Crawl job ID" },
      "total": { "type": "integer", "description": "[crawl] Total number of crawled pages" }
    },
    "description": "scrape→{url,title,text,...}, crawl→{crawlId,total,pages[]}, map→{links[]}, extract→extracted data"
  }
}
