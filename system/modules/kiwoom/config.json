{
  "name": "kiwoom",
  "type": "module",
  "scope": "system",
  "version": "1.0.0",
  "description": "키움증권 REST API — 국내주식 **정확한 수치·시세** 전용 (현재가/호가/차트/주문/잔고/순위/재무/업종/ELW/ETF/테마/조건검색 200+ API). 편의 액션 action:'price' symbol:'005930' 또는 apiId로 직접 호출. 한 호출 = 종목 1개 (N종목이면 N개 EXECUTE step 분리). 뉴스·배경·해석 등 텍스트 질문은 naver_search 사용.",
  "runtime": "node",
  "capability": "stock-trading",
  "providerType": "api",
  "secrets": ["KIWOOM_APP_KEY", "KIWOOM_APP_SECRET"],
  "tokenCache": { "key": "KIWOOM_ACCESS_TOKEN", "ttlHours": 23 },
  "input": {
    "type": "object",
    "required": ["action"],
    "properties": {
      "action": {
        "type": "string",
        "enum": [
          "price", "quote", "daily-price", "tick-data", "time-price", "after-hours",
          "chart-tick", "chart-minute", "chart-daily", "chart-weekly", "chart-monthly", "chart-yearly",
          "order-buy", "order-sell", "order-modify", "order-cancel",
          "credit-buy", "credit-sell", "credit-modify", "credit-cancel",
          "gold-buy", "gold-sell", "gold-modify", "gold-cancel",
          "account", "balance", "deposit", "asset", "evaluation",
          "unsettled", "settled", "daily-pnl", "realized-pnl", "today-pnl",
          "trade-log", "account-yield", "daily-deposit", "ccld-balance",
          "ccld-detail", "next-settle", "ccld-status", "withdraw-limit",
          "margin-qty", "credit-margin", "margin-detail", "trade-history",
          "daily-yield", "daily-status",
          "stock-info", "trade-broker", "execution", "credit-trend", "trade-detail",
          "stock-list", "stock-detail", "sector-list", "broker-list",
          "realtime-rank", "high-low", "limit-price", "near-highlow", "price-surge",
          "volume-renew", "price-cluster", "per-range", "open-change",
          "vi-trigger", "today-volume",
          "ranking-volume", "ranking-amount", "ranking-change", "ranking-foreign",
          "ranking-broker", "ranking-volume-surge", "ranking-quote", "ranking-quote-surge",
          "ranking-ratio-surge", "ranking-prev-vol", "ranking-credit-ratio",
          "ranking-foreign-cont", "ranking-foreign-limit", "ranking-foreign-window",
          "ranking-broker-trade", "ranking-today-broker", "ranking-net-broker",
          "ranking-overtime", "ranking-foreign-inst",
          "foreign-trade", "institution",
          "short-selling", "lending-trend", "lending-top10", "lending-by-stock", "lending-detail",
          "theme-list", "theme-stocks",
          "program-top50", "program-time", "program-arb", "program-cum",
          "program-by-stock", "program-daily", "program-by-stock-daily", "program-by-stock-info",
          "sector-investor", "sector-price", "sector-stocks", "sector-all", "sector-daily",
          "sector-tick-chart", "sector-minute-chart", "sector-daily-chart",
          "sector-weekly-chart", "sector-monthly-chart", "sector-yearly-chart",
          "etf-yield", "etf-info", "etf-daily", "etf-all",
          "gold-price", "gold-quote", "gold-balance", "gold-deposit",
          "gold-ccld", "gold-detail", "gold-history", "gold-unsettled",
          "gold-tick-chart", "gold-minute-chart", "gold-daily-chart",
          "gold-ccnl", "gold-daily-trend", "gold-investor",
          "inst-daily", "inst-trend", "strength-time", "strength-daily",
          "broker-trend", "investor-by-stock", "inst-by-stock", "inst-total",
          "same-net", "intraday-inv", "afterclose-inv", "inst-cont",
          "cond-list", "cond-search", "cond-realtime", "cond-cancel",
          "credit-avail", "credit-inquiry"
        ],
        "description": "편의 액션명 (영문 그대로 사용). price=현재가, quote=호가, balance=잔고, chart-daily=일봉, ranking-volume=거래량순위 등. 또는 apiId(ka10001 등)를 직접 지정."
      },
      "symbol": {
        "type": "string",
        "description": "종목코드. 보통 6자리 숫자 (005930=삼성전자) — 단 ETN/ETF/일부 신규상장 종목은 영문 포함 6자리 (예: 0011T0=채비). 형식 검증 X — 받은 코드 그대로 API 에 전달."
      },
      "params": {
        "type": "object",
        "description": "API별 추가 파라미터 (apiId 직접 호출 시 사용)"
      },
      "quantity": {
        "type": "integer",
        "minimum": 1,
        "description": "주문 수량"
      },
      "price": {
        "type": "integer",
        "minimum": 0,
        "description": "주문 가격 (0=시장가)"
      },
      "orderNo": {
        "type": "string",
        "description": "원주문번호 (정정/취소 시 필수)"
      },
      "count": {
        "type": "integer",
        "default": 30,
        "description": "차트 조회 건수"
      },
      "mock": {
        "type": "boolean",
        "default": false,
        "description": "모의투자 여부 (기본값: false=실전투자)"
      }
    },
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "required": ["apiId"],
    "properties": {
      "apiId": { "type": "string", "description": "호출된 API ID" },
      "action": { "type": "string", "description": "요청한 액션명" },
      "data": { "type": "object", "description": "API 응답 데이터 (API별로 다름)" }
    },
    "additionalProperties": true
  }
}
