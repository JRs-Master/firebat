# 의존성 폴더
node_modules/

# 참조용 외부 문서 (xlsx) — git 관리 X, 작업 시 로컬에 두고 참조
*.xlsx

# Next.js 빌드 결과물
.next/
out/
build/
tsconfig.tsbuildinfo

# 환경 변수
.env
.env.local
.env.development
.env.production

# IDE/도구 로컬 설정
.claude/
.vscode/

# Claude Code 작업 기록
CLAUDE.md

# Firebat AI 자율 메모리 인덱스 (data/firebat-memory/ 본문은 data/ 로 자동 gitignored)
firebat.md

# 시스템 파일
.DS_Store
Thumbs.db

# 런타임 데이터 (DB, 로그, 크론, MCP 설정 등) — root data/ 만 ignore.
# 옛 commit 대상 데이터는 2026-05-17 이후 system/ 디렉토리로 통일 (llm/models.json, modules/{name}/_apis.json).
/data/
*.db

# lock 파일 제외 (package-lock.json은 유지)
yarn.lock
pnpm-lock.yaml

# Cargo workspace target — Rust 빌드 산출물 (~수십 GB 가능)
/target/
core/target/
infra/target/

# Python 바이트코드 캐시 (py_compile / 모듈 실행 산물)
__pycache__/
*.pyc
