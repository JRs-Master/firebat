  "scope": "system",
  "version": "1.0.0",
  "description": "Jina Reader API 기반 웹 스크래퍼. URL → HTML 원본 반환. 서버 리소스 제로.",
  "runtime": "node",
  "capability": "web-scrape",
  "providerType": "api",
  "secrets": [],
