{
  "name": "cms",
  "type": "service",
  "scope": "system",
  "version": "1.0.0",
  "description": "CMS 설정 (사이트 메타·테마·레이아웃·SEO·OG·스크립트·소유권 인증 파일·태그). 이전 SEO 모듈에서 확장.",
  "runtime": "none",
  "settings_fields": [
    { "key": "siteTitle", "type": "text", "tab": "일반", "placeholder": "Firebat" },
    { "key": "siteDescription", "type": "text", "tab": "일반", "placeholder": "Just Imagine. Firebat Runs." },
    { "key": "siteUrl", "type": "text", "tab": "일반", "placeholder": "https://example.com" },
    { "key": "jsonLdEnabled", "type": "toggle", "tab": "일반", "defaultValue": true },
    { "key": "jsonLdOrganization", "type": "text", "tab": "일반", "placeholder": "Firebat" },
    { "key": "jsonLdLogoUrl", "type": "text", "tab": "일반", "placeholder": "https://example.com/icon.svg" },
    { "key": "siteLang", "type": "text", "tab": "일반", "placeholder": "ko", "defaultValue": "ko" },
    { "key": "faviconUrl", "type": "text", "tab": "일반", "placeholder": "/user/media/...png 또는 https://..." },

    { "key": "layoutShowHeader", "type": "toggle", "tab": "레이아웃", "group": "헤더", "defaultValue": true },
    { "key": "layoutSiteName", "type": "text", "tab": "레이아웃", "group": "헤더", "placeholder": "(비우면 일반 탭의 사이트 제목 사용)" },
    { "key": "layoutLogoUrl", "type": "text", "tab": "레이아웃", "group": "헤더", "placeholder": "/user/media/...png 또는 https://..." },
    { "key": "layoutNavLinks", "type": "textarea", "tab": "레이아웃", "group": "헤더", "placeholder": "홈 | /\n블로그 | /blog\n소개 | /about\n문의 | /contact" },
    { "key": "layoutHeaderSticky", "type": "toggle", "tab": "레이아웃", "group": "헤더", "defaultValue": false },
    { "key": "layoutHeaderTransparentOnTop", "type": "toggle", "tab": "레이아웃", "group": "헤더", "defaultValue": false },
    { "key": "layoutHeaderMobileDrawer", "type": "toggle", "tab": "레이아웃", "group": "헤더", "defaultValue": false },
    { "key": "layoutHeaderMobileDrawerIncludeSidebar", "type": "toggle", "tab": "레이아웃", "group": "헤더", "defaultValue": false },
    { "key": "headerWidgetsLeft", "type": "widget-list", "widgetArea": "header", "tab": "레이아웃", "group": "헤더" },
    { "key": "headerWidgetsCenter", "type": "widget-list", "widgetArea": "header", "tab": "레이아웃", "group": "헤더" },
    { "key": "headerWidgetsRight", "type": "widget-list", "widgetArea": "header", "tab": "레이아웃", "group": "헤더" },

    {
      "key": "layoutMode",
      "type": "select",
      "tab": "레이아웃",
      "group": "사이드바",
      "defaultValue": "full",
      "options": [
        { "value": "full", "label": "Full — 사이드바 없음 (기본)" },
        { "value": "right-sidebar", "label": "Right Sidebar — 우측 사이드바" },
        { "value": "left-sidebar", "label": "Left Sidebar — 좌측 사이드바" },
        { "value": "both-sidebar", "label": "Both Sidebar — 양쪽 사이드바" },
        { "value": "boxed", "label": "Boxed — 사이드바 없음 + 본문 boxed" }
      ]
    },
    { "key": "sidebarWidgets", "type": "widget-list", "widgetArea": "sidebar", "tab": "레이아웃", "group": "사이드바" },
    { "key": "sidebarShowSearchBox", "type": "toggle", "tab": "레이아웃", "group": "사이드바", "defaultValue": false },
    { "key": "sidebarShowRecentPosts", "type": "toggle", "tab": "레이아웃", "group": "사이드바", "defaultValue": true },
    { "key": "sidebarRecentPostsCount", "type": "number", "tab": "레이아웃", "group": "사이드바", "placeholder": "5", "defaultValue": 5 },
    { "key": "sidebarShowCategoryList", "type": "toggle", "tab": "레이아웃", "group": "사이드바", "defaultValue": false },
    { "key": "sidebarShowTagCloud", "type": "toggle", "tab": "레이아웃", "group": "사이드바", "defaultValue": false },
    { "key": "sidebarTagCloudLimit", "type": "number", "tab": "레이아웃", "group": "사이드바", "placeholder": "20", "defaultValue": 20 },
    { "key": "sidebarShowSubscribe", "type": "toggle", "tab": "레이아웃", "group": "사이드바", "defaultValue": false },
    { "key": "sidebarHtmlWidget", "type": "textarea", "tab": "레이아웃", "group": "사이드바", "placeholder": "<div>광고 코드 / 연락처 / 소개 등</div>" },

    { "key": "layoutShowFooter", "type": "toggle", "tab": "레이아웃", "group": "푸터", "defaultValue": true },
    { "key": "layoutFooterText", "type": "textarea", "tab": "레이아웃", "group": "푸터", "placeholder": "© 2026 사이트명. All rights reserved." },
    { "key": "footerWidgetsCol1", "type": "widget-list", "widgetArea": "footer", "tab": "레이아웃", "group": "푸터" },
    { "key": "footerWidgetsCol2", "type": "widget-list", "widgetArea": "footer", "tab": "레이아웃", "group": "푸터" },
    { "key": "footerWidgetsCol3", "type": "widget-list", "widgetArea": "footer", "tab": "레이아웃", "group": "푸터" },
    { "key": "footerWidgetsCol4", "type": "widget-list", "widgetArea": "footer", "tab": "레이아웃", "group": "푸터" },
    { "key": "footerColumn1Heading", "type": "text", "tab": "레이아웃", "group": "푸터", "placeholder": "회사 소개" },
    { "key": "footerColumn1Content", "type": "textarea", "tab": "레이아웃", "group": "푸터", "placeholder": "<a href=\"/about\">소개</a><br><a href=\"/contact\">연락처</a>" },
    { "key": "footerColumn2Heading", "type": "text", "tab": "레이아웃", "group": "푸터", "placeholder": "카테고리" },
    { "key": "footerColumn2Content", "type": "textarea", "tab": "레이아웃", "group": "푸터", "placeholder": "<a href=\"/blog\">블로그</a>" },
    { "key": "footerColumn3Heading", "type": "text", "tab": "레이아웃", "group": "푸터", "placeholder": "구독" },
    { "key": "footerColumn3Content", "type": "textarea", "tab": "레이아웃", "group": "푸터", "placeholder": "<a href=\"/feed.xml\">RSS</a>" },
    { "key": "footerColumn4Heading", "type": "text", "tab": "레이아웃", "group": "푸터", "placeholder": "소셜" },
    { "key": "footerColumn4Content", "type": "textarea", "tab": "레이아웃", "group": "푸터", "placeholder": "<a href=\"https://x.com/me\">X</a>" },

    {
      "key": "pageListCardVariant",
      "type": "select",
      "tab": "레이아웃",
      "group": "본문 · 글 list",
      "defaultValue": "list",
      "options": [
        { "value": "list", "label": "List — 세로 카드 (기본)" },
        { "value": "grid", "label": "Grid — 격자 2-3열" },
        { "value": "compact", "label": "Compact — 제목+날짜 압축" },
        { "value": "magazine", "label": "Magazine — 잡지 (hero + 2열 카드)" }
      ]
    },
    { "key": "pageListPerPage", "type": "number", "tab": "레이아웃", "group": "본문 · 글 list", "placeholder": "20", "defaultValue": 20 },
    { "key": "layoutShowReadingProgress", "type": "toggle", "tab": "레이아웃", "group": "본문 · 글 list", "defaultValue": false },
    { "key": "layoutShowRelatedPosts", "type": "toggle", "tab": "레이아웃", "group": "본문 · 글 list", "defaultValue": true },
    { "key": "layoutRelatedPostsCount", "type": "number", "tab": "레이아웃", "group": "본문 · 글 list", "placeholder": "5", "defaultValue": 5 },

    { "key": "adsensePublisherId", "type": "text", "tab": "광고", "placeholder": "ca-pub-1234567890123456" },
    { "key": "adsenseSlotHeaderBottom", "type": "text", "tab": "광고", "placeholder": "1234567890" },
    { "key": "adsenseSlotPostTop", "type": "text", "tab": "광고", "placeholder": "1234567890" },
    { "key": "adsenseSlotPostBottom", "type": "text", "tab": "광고", "placeholder": "1234567890" },
    { "key": "adsenseSlotFooterTop", "type": "text", "tab": "광고", "placeholder": "1234567890" },

    { "key": "themePreset", "type": "color-presets", "tab": "테마", "group": "색", "defaultValue": "slate-pro" },
    { "key": "__themeColorOverrides", "type": "color-overrides", "tab": "테마", "group": "색" },
    {
      "key": "themeFont",
      "type": "select",
      "tab": "테마",
      "group": "폰트",
      "defaultValue": "pretendard",
      "options": [
        { "value": "pretendard", "label": "Pretendard Variable (한글, 기본)" },
        { "value": "noto-sans-kr", "label": "Noto Sans KR" },
        { "value": "inter", "label": "Inter (라틴)" },
        { "value": "geist", "label": "Geist (모노크롬)" },
        { "value": "cal-sans", "label": "Cal Sans (제목 강조)" }
      ]
    },
    { "key": "customFontUrls", "type": "textarea", "tab": "테마", "group": "폰트", "placeholder": "https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" },
    { "key": "themeFont_body", "type": "text", "tab": "테마", "group": "폰트", "placeholder": "'Inter', sans-serif" },
    { "key": "themeFont_heading", "type": "text", "tab": "테마", "group": "폰트", "placeholder": "'Cal Sans', sans-serif" },
    { "key": "themeFont_mono", "type": "text", "tab": "테마", "group": "폰트", "placeholder": "'JetBrains Mono', monospace" },

    { "key": "themeBaseFontSize", "type": "text", "tab": "테마", "group": "타이포그래피", "placeholder": "16px" },
    { "key": "themeScaleRatio", "type": "number", "tab": "테마", "group": "타이포그래피", "placeholder": "1.25" },
    { "key": "themeBodyLineHeight", "type": "number", "tab": "테마", "group": "타이포그래피", "placeholder": "1.7" },
    { "key": "themeHeadingLineHeight", "type": "number", "tab": "테마", "group": "타이포그래피", "placeholder": "1.25" },
    { "key": "themeHeadingLetterSpacing", "type": "text", "tab": "테마", "group": "타이포그래피", "placeholder": "-0.01em" },
    { "key": "themeBodyLetterSpacing", "type": "text", "tab": "테마", "group": "타이포그래피", "placeholder": "normal" },

    {
      "key": "themeH1Style",
      "type": "select",
      "tab": "테마",
      "group": "제목 스타일",
      "defaultValue": "plain",
      "options": [
        { "value": "plain", "label": "plain (단순)" },
        { "value": "border-bottom", "label": "border-bottom (밑줄)" },
        { "value": "border-left", "label": "border-left (좌측 accent 바)" },
        { "value": "underline", "label": "underline (텍스트 밑줄)" },
        { "value": "bold-bg", "label": "bold-bg (강조 배경 박스)" },
        { "value": "accent-square", "label": "accent-square (사각형 prefix)" }
      ]
    },
    {
      "key": "themeH2Style",
      "type": "select",
      "tab": "테마",
      "group": "제목 스타일",
      "defaultValue": "border-left",
      "options": [
        { "value": "plain", "label": "plain (단순)" },
        { "value": "border-bottom", "label": "border-bottom (밑줄)" },
        { "value": "border-left", "label": "border-left (좌측 accent 바, 기본)" },
        { "value": "underline", "label": "underline (텍스트 밑줄)" },
        { "value": "bold-bg", "label": "bold-bg (강조 배경 박스)" },
        { "value": "accent-square", "label": "accent-square (사각형 prefix)" }
      ]
    },
    {
      "key": "themeH3Style",
      "type": "select",
      "tab": "테마",
      "group": "제목 스타일",
      "defaultValue": "plain",
      "options": [
        { "value": "plain", "label": "plain (단순, 기본)" },
        { "value": "border-bottom", "label": "border-bottom (밑줄)" },
        { "value": "border-left", "label": "border-left (좌측 accent 바)" },
        { "value": "underline", "label": "underline (텍스트 밑줄)" },
        { "value": "bold-bg", "label": "bold-bg (강조 배경 박스)" },
        { "value": "accent-square", "label": "accent-square (사각형 prefix)" }
      ]
    },

    { "key": "themeContentMaxWidth", "type": "text", "tab": "테마", "group": "본문 폭 · 여백 · 모서리", "placeholder": "1200px", "defaultValue": "1200px" },
    { "key": "themePaddingMobile", "type": "text", "tab": "테마", "group": "본문 폭 · 여백 · 모서리", "placeholder": "16px", "defaultValue": "16px" },
    { "key": "themePaddingTablet", "type": "text", "tab": "테마", "group": "본문 폭 · 여백 · 모서리", "placeholder": "24px", "defaultValue": "24px" },
    { "key": "themePaddingDesktop", "type": "text", "tab": "테마", "group": "본문 폭 · 여백 · 모서리", "placeholder": "32px", "defaultValue": "32px" },
    { "key": "themeRadius", "type": "text", "tab": "테마", "group": "본문 폭 · 여백 · 모서리", "placeholder": "8px", "defaultValue": "8px" },

    { "key": "sitemapEnabled", "type": "toggle", "tab": "SEO", "defaultValue": true },
    { "key": "rssEnabled", "type": "toggle", "tab": "SEO", "defaultValue": true },
    { "key": "robotsTxt", "type": "textarea", "tab": "SEO", "placeholder": "User-agent: *\nAllow: /\nDisallow: /api\nDisallow: /admin", "defaultValue": "User-agent: *\nAllow: /\nDisallow: /api\nDisallow: /admin" },
    { "key": "autoCanonical", "type": "toggle", "tab": "SEO", "defaultValue": true },
    { "key": "twitterCardType", "type": "text", "tab": "SEO", "placeholder": "summary_large_image", "defaultValue": "summary_large_image" },
    { "key": "twitterSite", "type": "text", "tab": "SEO", "placeholder": "@firebat" },
    { "key": "twitterCreator", "type": "text", "tab": "SEO", "placeholder": "@username" },
    { "key": "tagAliases", "type": "textarea", "tab": "SEO", "placeholder": "AI: ai, 인공지능, artificial-intelligence\n리뷰: review, 후기" },

    { "key": "imageWebp", "type": "toggle", "tab": "이미지", "defaultValue": true },
    { "key": "imageAvif", "type": "toggle", "tab": "이미지", "defaultValue": true },
    { "key": "imageThumbnail", "type": "toggle", "tab": "이미지", "defaultValue": true },
    { "key": "imageBlurhash", "type": "toggle", "tab": "이미지", "defaultValue": true },
    { "key": "imageVariants", "type": "text", "tab": "이미지", "placeholder": "480, 768, 1024", "defaultValue": "480, 768, 1024" },
    { "key": "imageDefaultQuality", "type": "number", "tab": "이미지", "placeholder": "85", "defaultValue": 85 },
    { "key": "imageStripExif", "type": "toggle", "tab": "이미지", "defaultValue": true },
    { "key": "imageProgressive", "type": "toggle", "tab": "이미지", "defaultValue": true },
    { "key": "imageKeepOriginal", "type": "toggle", "tab": "이미지", "defaultValue": true },

    { "key": "ogBgColor", "type": "text", "tab": "OG", "placeholder": "#f8fafc" },
    { "key": "ogAccentColor", "type": "text", "tab": "OG", "placeholder": "#2563eb" },
    { "key": "ogDomain", "type": "text", "tab": "OG", "placeholder": "example.com" },

    { "key": "headScripts", "type": "textarea", "tab": "스크립트", "placeholder": "<!-- Google Analytics 등 -->" },
    { "key": "bodyScripts", "type": "textarea", "tab": "스크립트", "placeholder": "<!-- 채팅 위젯 등 -->" },
    { "key": "adsTxt", "type": "textarea", "tab": "스크립트", "placeholder": "google.com, pub-XXXXXXXX, DIRECT, f08c47fec0942fa0" },
    { "key": "verifications", "type": "verifications", "tab": "스크립트" }
  ]
}
