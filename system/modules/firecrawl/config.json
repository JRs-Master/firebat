{
  "name": "firecrawl",
  "type": "module",
  "scope": "system",
  "version": "2.0.0",
  "description": "Firecrawl API v1 기반 웹 스크래퍼. 4가지 액션: scrape(단일 URL 스크래핑), crawl(사이트 전체 크롤링), map(URL 목록 수집), extract(LLM 구조화 데이터 추출). JS 렌더링·브라우저 액션(click/write/press/scroll/wait/screenshot)·LLM JSON 추출·위치 기반 스크래핑 지원.",
  "runtime": "node",
  "capability": "web-scrape",
  "providerType": "api",
  "secrets": ["FIRECRAWL_API_KEY"],
  "input": {
    "type": "object",
    "properties": {
      "action": {
        "type": "string",
        "enum": ["scrape", "crawl", "map", "extract"],
        "default": "scrape",
        "description": "scrape=단일 URL 스크래핑, crawl=사이트 전체 크롤링, map=URL 목록 수집(스크래핑 없음), extract=LLM 구조화 데이터 추출"
      },
      "url": {
        "type": "string",
        "description": "[scrape/crawl/map] 대상 URL"
      },
      "urls": {
        "type": "array",
        "items": { "type": "string" },
        "description": "[extract] 대상 URL 배열. 와일드카드 지원 (example.com/*)"
      },
      "keyword": {
        "type": "string",
        "description": "[scrape] 키워드 포함 섹션만 추출 (자체 후처리)"
      },
      "formats": {
        "type": "array",
        "items": { "type": "string", "enum": ["markdown", "html", "rawHtml", "json", "links", "screenshot", "screenshot@fullPage"] },
        "default": ["markdown"],
        "description": "[scrape] 반환 포맷. json=LLM 구조화 추출 (jsonOptions 필요)"
      },
      "onlyMainContent": {
        "type": "boolean",
        "default": true,
        "description": "[scrape] 메인 콘텐츠만 추출 (nav/footer 제외)"
      },
      "includeTags": {
        "type": "array",
        "items": { "type": "string" },
        "description": "[scrape] 포함할 HTML 태그 목록"
      },
      "excludeTags": {
        "type": "array",
        "items": { "type": "string" },
        "description": "[scrape] 제외할 HTML 태그 목록"
      },
      "headers": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "[scrape] 커스텀 HTTP 헤더"
      },
      "waitFor": {
        "type": "integer",
        "description": "[scrape] 페이지 로드 후 대기 (ms). CSS 선택자 문자열도 가능"
      },
      "timeout": {
        "type": "integer",
        "default": 30000,
        "description": "[scrape] 요청 타임아웃 (ms)"
      },
      "mobile": {
        "type": "boolean",
        "default": false,
        "description": "[scrape] 모바일 뷰포트 사용"
      },
      "skipTlsVerification": {
        "type": "boolean",
        "default": false,
        "description": "[scrape] TLS 인증서 검증 건너뛰기"
      },
      "removeBase64Images": {
        "type": "boolean",
        "default": true,
        "description": "[scrape] base64 이미지 제거"
      },
      "maxAge": {
        "type": "integer",
        "default": 0,
        "description": "[scrape] 캐시 최대 수명 (ms). 0=캐시 미사용"
      },
      "location": {
        "type": "object",
        "properties": {
          "country": { "type": "string", "description": "ISO 3166-1 alpha-2 국가코드 (US, KR 등)" },
          "languages": { "type": "array", "items": { "type": "string" }, "description": "선호 언어 배열 (ko, en 등)" }
        },
        "description": "[scrape/map] 위치/언어 기반 스크래핑"
      },
      "actions": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["click", "write", "press", "scroll", "wait", "screenshot", "scrape", "executeJavaScript"], "description": "액션 타입" },
            "selector": { "type": "string", "description": "[click/write] CSS 선택자" },
            "text": { "type": "string", "description": "[write] 입력할 텍스트" },
            "key": { "type": "string", "description": "[press] 키보드 키 (Enter, Tab 등)" },
            "milliseconds": { "type": "integer", "description": "[wait] 대기 시간 (ms)" },
            "fullPage": { "type": "boolean", "description": "[screenshot] 전체 페이지 캡처" },
            "direction": { "type": "string", "enum": ["up", "down"], "description": "[scroll] 스크롤 방향" },
            "amount": { "type": "integer", "description": "[scroll] 스크롤 양 (px)" },
            "script": { "type": "string", "description": "[executeJavaScript] JS 코드" }
          }
        },
        "description": "[scrape] 스크래핑 전 브라우저 액션 배열. 로그인, 버튼 클릭, 무한 스크롤 등"
      },
      "jsonOptions": {
        "type": "object",
        "properties": {
          "schema": { "type": "object", "description": "JSON Schema로 추출할 데이터 구조 정의" },
          "prompt": { "type": "string", "description": "추출할 데이터 자연어 설명" },
          "systemPrompt": { "type": "string", "description": "LLM 시스템 프롬프트" }
        },
        "description": "[scrape] formats에 'json' 포함 시 LLM 기반 구조화 추출 옵션"
      },
      "limit": {
        "type": "integer",
        "description": "[crawl] 최대 페이지 수 (기본 10000). [map] 최대 URL 수"
      },
      "maxDiscoveryDepth": {
        "type": "integer",
        "description": "[crawl] 루트 URL 기준 최대 링크 깊이"
      },
      "includePaths": {
        "type": "array",
        "items": { "type": "string" },
        "description": "[crawl] 포함할 URL 경로 정규식 패턴"
      },
      "excludePaths": {
        "type": "array",
        "items": { "type": "string" },
        "description": "[crawl] 제외할 URL 경로 정규식 패턴"
      },
      "crawlEntireDomain": {
        "type": "boolean",
        "default": false,
        "description": "[crawl] 상위/형제 URL까지 크롤"
      },
      "allowSubdomains": {
        "type": "boolean",
        "default": false,
        "description": "[crawl] 서브도메인까지 크롤"
      },
      "allowExternalLinks": {
        "type": "boolean",
        "default": false,
        "description": "[crawl/extract] 외부 링크 따라가기"
      },
      "sitemap": {
        "type": "string",
        "enum": ["include", "skip", "only"],
        "description": "[crawl] 사이트맵 처리. include=포함, skip=무시, only=사이트맵만"
      },
      "ignoreQueryParameters": {
        "type": "boolean",
        "default": false,
        "description": "[crawl] 쿼리 파라미터 다른 같은 경로 중복 방지"
      },
      "delay": {
        "type": "number",
        "description": "[crawl] 스크래핑 간격 (초)"
      },
      "maxConcurrency": {
        "type": "integer",
        "description": "[crawl] 최대 동시 스크래핑 수"
      },
      "scrapeOptions": {
        "type": "object",
        "description": "[crawl] 각 페이지 스크래핑 옵션 (formats, actions 등)"
      },
      "search": {
        "type": "string",
        "description": "[map] 특정 URL 검색 키워드"
      },
      "prompt": {
        "type": "string",
        "description": "[extract] 추출할 데이터 자연어 설명"
      },
      "schema": {
        "type": "object",
        "description": "[extract] JSON Schema로 추출할 데이터 구조 정의"
      },
      "systemPrompt": {
        "type": "string",
        "description": "[extract] LLM 시스템 프롬프트"
      },
      "enableWebSearch": {
        "type": "boolean",
        "description": "[extract] 웹 검색으로 관련 정보 보강"
      },
      "showSources": {
        "type": "boolean",
        "description": "[extract] 출처 URL 표시"
      },
      "maxWaitMs": {
        "type": "integer",
        "default": 300000,
        "description": "[crawl/extract] 최대 대기 시간 (ms). crawl 기본 5분, extract 기본 2분"
      },
      "pollInterval": {
        "type": "integer",
        "default": 5000,
        "description": "[crawl] 폴링 간격 (ms)"
      }
    },
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "properties": {
      "url": { "type": "string", "description": "[scrape] 최종 URL" },
      "title": { "type": "string", "description": "[scrape] 페이지 제목" },
      "text": { "type": "string", "description": "[scrape] 마크다운 본문" },
      "html": { "type": "string", "description": "[scrape] HTML (formats에 html 포함 시)" },
      "links": { "type": "array", "description": "[scrape/map] 링크 목록" },
      "screenshot": { "type": "string", "description": "[scrape] 스크린샷 URL" },
      "json": { "type": "object", "description": "[scrape] LLM 추출 JSON (formats에 json 포함 시)" },
      "pages": { "type": "array", "description": "[crawl] 크롤링된 페이지 배열 [{url, title, text}]" },
      "crawlId": { "type": "string", "description": "[crawl] 크롤 작업 ID" },
      "total": { "type": "integer", "description": "[crawl] 총 크롤 페이지 수" }
    },
    "description": "scrape→{url,title,text,...}, crawl→{crawlId,total,pages[]}, map→{links[]}, extract→추출 데이터"
  }
}
